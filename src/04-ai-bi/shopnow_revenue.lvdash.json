{
  "datasets": [
    {
      "name": "revenue_trend",
      "displayName": "Revenue Trend (Last 90 Days)",
      "query": "SELECT order_day, SUM(total_revenue) AS revenue, SUM(order_count) AS orders, AVG(avg_order_value) AS avg_order_value FROM gold_revenue_daily WHERE order_day >= DATEADD(day, -90, (SELECT MAX(order_day) FROM gold_revenue_daily)) GROUP BY order_day ORDER BY order_day"
    },
    {
      "name": "revenue_by_country",
      "displayName": "Revenue by Country",
      "query": "SELECT ship_country AS country, SUM(total_revenue) AS total_revenue, SUM(order_count) AS total_orders, ROUND(SUM(returns) / NULLIF(SUM(order_count), 0) * 100, 1) AS return_rate_pct FROM gold_revenue_daily GROUP BY ship_country ORDER BY total_revenue DESC"
    },
    {
      "name": "top_products",
      "displayName": "Top 10 Products",
      "query": "SELECT product_name, category, brand, units_sold, total_revenue, margin_pct, return_rate_pct FROM gold_top_products ORDER BY total_revenue DESC LIMIT 10"
    },
    {
      "name": "cart_abandonment",
      "displayName": "Cart Abandonment Trend",
      "query": "SELECT DATE(session_start) AS day, COUNT(*) AS total_sessions, SUM(CASE WHEN abandoned THEN 1 ELSE 0 END) AS abandoned_sessions, ROUND(SUM(CASE WHEN abandoned THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0) * 100, 1) AS abandonment_rate_pct FROM gold_cart_abandonment GROUP BY DATE(session_start) ORDER BY day"
    },
    {
      "name": "customer_ltv",
      "displayName": "Customer Segment LTV",
      "query": "SELECT segment, country, COUNT(customer_id) AS customer_count, ROUND(AVG(lifetime_value), 2) AS avg_ltv, ROUND(AVG(total_orders), 1) AS avg_orders, SUM(CASE WHEN is_active THEN 1 ELSE 0 END) AS active_customers FROM gold_customer_ltv GROUP BY segment, country ORDER BY avg_ltv DESC"
    }
  ],
  "pages": [
    {
      "name": "overview",
      "displayName": "ShopNow Revenue Intelligence",
      "layout": [
        {
          "position": { "x": 0, "y": 0, "width": 6, "height": 1 },
          "widget": {
            "name": "title",
            "textbox_spec": "# ShopNow Revenue Intelligence"
          }
        },
        {
          "position": { "x": 0, "y": 1, "width": 6, "height": 1 },
          "widget": {
            "name": "subtitle",
            "textbox_spec": "Daily & weekly revenue, top products, cart abandonment, and customer LTV. Built on gold tables."
          }
        },
        {
          "position": { "x": 0, "y": 2, "width": 2, "height": 3 },
          "widget": {
            "name": "total-revenue",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "revenue_trend",
                  "disaggregated": false,
                  "fields": [
                    { "name": "sum(revenue)", "expression": "SUM(`revenue`)" }
                  ]
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": { "fieldName": "sum(revenue)", "displayName": "Total Revenue (90d)" }
              },
              "frame": { "showTitle": true, "title": "Total Revenue (90d)" }
            }
          }
        },
        {
          "position": { "x": 2, "y": 2, "width": 2, "height": 3 },
          "widget": {
            "name": "total-orders",
