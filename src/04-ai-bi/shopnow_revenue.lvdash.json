              {
                "name": "main_query",
                "query": {
                  "datasetName": "revenue_trend",
                  "disaggregated": false,
                  "fields": [
                    { "name": "sum(orders)", "expression": "SUM(`orders`)" }
                  ]
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": { "fieldName": "sum(orders)", "displayName": "Total Orders (90d)" }
